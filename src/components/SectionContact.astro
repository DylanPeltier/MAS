---
import { Icon } from "astro-icon/components";
---

<section
	id="contact"
	class="mas-scroll-section mx-auto w-full max-w-7xl px-4 pb-16 pt-8 md:px-6 md:pb-24 md:pt-10"
	aria-labelledby="contact-heading"
	data-reveal
>
	<div
		class="rounded-3xl bg-gradient-to-br from-neutral-800 via-neutral-900 to-[#2A3841] px-6 py-12 text-center shadow-lg shadow-[#2A3841]/40 ring-1 ring-white/10 md:px-12 md:py-16"
	>
		<h2 id="contact-heading" class="text-2xl font-bold text-white md:text-3xl">
			Contact us
		</h2>
		<p class="mx-auto mt-3 max-w-xl text-neutral-300">
			Tell us what is going on. We will follow up with next steps.
		</p>
		<div class="mt-8 flex justify-center">
			<a href="tel:+12268861889" class="mas-btn-primary-lg">
				<Icon
					name="heroicons:phone-solid"
					aria-hidden="true"
					class="!h-4 !w-4 sm:!h-5 sm:!w-5"
				/>
				226-886-1889
			</a>
		</div>
		<p class="mt-6 text-neutral-300">
			Email: <a
				href="mailto:malcolmsapplianceservice@gmail.com"
				class="break-all font-medium text-white underline underline-offset-2 hover:text-[#94ACB8]"
			>
				malcolmsapplianceservice@gmail.com
			</a>
		</p>
	</div>
</section>
