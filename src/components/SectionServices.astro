---
const items = [
	{
		title: "Dishwashers",
		body: "Leaks, draining problems, poor cleaning, odd noises, and error codes: we find the cause and fix it so every cycle leaves dishes clean.",
	},
	{
		title: "Washers",
		body: "Front-load and top-load washers with spin problems, leaks, balance issues, or cycle failures. You get clear explanations and dependable repairs.",
	},
	{
		title: "Dryers",
		body: "Electric dryers: no heat, long dry times, drum noise, and airflow issues. We restore efficient, safe drying and flag vent problems when they matter.",
	},
	{
		title: "Ovens",
		body: "Wall ovens and ranges with temperature issues, uneven baking, or control faults, repaired so your kitchen cooks the way you expect.",
	},
];
---

<section
	id="services"
	class="mas-scroll-section bg-neutral-50 py-16 md:py-24"
	aria-labelledby="services-heading"
	data-reveal
>
	<div class="mx-auto max-w-7xl px-4 md:px-6">
		<h2 id="services-heading" class="text-3xl font-bold tracking-tight text-neutral-900 md:text-4xl">
			Services
		</h2>
		<p class="mt-3 max-w-2xl text-lg text-neutral-600">
			What we offer for the appliances you rely on every day.
		</p>
		<ul class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8 xl:grid-cols-3">
			{
				items.map((item) => (
					<li class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
						<h3 class="text-lg font-semibold text-neutral-900">{item.title}</h3>
						<p class="mt-2 text-neutral-600">{item.body}</p>
					</li>
				))
			}
		</ul>
	</div>
</section>
