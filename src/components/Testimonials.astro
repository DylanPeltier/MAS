---
const reviews = [
	{
		name: "Synthia Trembley",
		text: "I highly recommend Malcolm's Appliance Service! He is very knowledgable, quick & honest . Had my dryer fixed within the hour. Thankful I googled a local Service and now have a dependable Repair man for future. Thanks alot Malcolm, appreciate it. Synthia",
	},
	{
		name: "Brownwyn Sol",
		text: "I would absolutely recommend Malcolm to anyone needing appliance repairs. He provides exceptional service, is incredibly diligent, and knows his stuff.",
	},
	{
		name: "Kristen Scheele",
		text: "So impressed with Malcolm and the repairs on my dryer and dishwasher! He was professional, kind and very reasonably priced! I've had repair guys out in the past that just want to discard of the appliances where Malcolm takes the time to figure out the issue and solutions! Highly recommend! Give him a call!",
	},
	{
		name: "Anita Rabideau",
		text: "We called Malcolm on a holiday Monday. He called us back almost immediately. He came the next day. He informed us within an hour how much the parts would cost to fix our Maytag washing machine. He is quick, honest, and his rate is very reasonable. We will definitely call him for any appliance repairs we may have in the future. I would highly recommend his service to anyone. Thank you Malcolm!",
	},
	{
		name: "Christina",
		text: "Had Malcolm come and repair my fridge after it started smoking at the back - couldn't believe how fast it was fixed! He kept me informed about what was happening and updated me on when the part came in for the fridge, and the price was very reasonable. Definitely a great choice for appliance repair here in Wallaceburg!!",
	},
];
---

<section
	id="testimonials"
	class="mas-scroll-section mx-auto w-full max-w-7xl px-4 pb-8 pt-16 md:px-6 md:pb-10 md:pt-24"
	aria-labelledby="testimonials-heading"
	data-reveal
>
	<h2
		id="testimonials-heading"
		class="text-3xl font-bold tracking-tight text-neutral-900 md:text-4xl"
	>
		Customer reviews
	</h2>
	<p class="mt-3 max-w-2xl text-lg text-neutral-600">
		What people are saying about Malcolm&apos;s Appliance Service.
	</p>
	<ul class="mt-10 grid list-none grid-cols-1 gap-6 p-0 sm:grid-cols-2 sm:gap-8 xl:grid-cols-3">
		{
			reviews.map((item) => (
				<li>
					<article
						class="h-full rounded-2xl bg-neutral-100 p-6 shadow-sm"
						aria-label={`Review from ${item.name}`}
					>
						<div
							class="flex items-center gap-0.5 text-[#56717F]"
							role="img"
							aria-label="Rated 5 out of 5 stars"
						>
							{Array.from({ length: 5 }).map(() => (
								<svg
									viewBox="0 0 20 20"
									fill="currentColor"
									aria-hidden="true"
									class="h-4 w-4"
								>
									<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.364 1.118l1.287 3.957c.3.921-.755 1.688-1.54 1.118l-3.37-2.448a1 1 0 00-1.175 0l-3.37 2.448c-.784.57-1.838-.197-1.539-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.05 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.957z" />
								</svg>
							))}
						</div>
						<blockquote class="mt-3 text-sm leading-relaxed text-neutral-700">
							<p>{item.text}</p>
							<footer class="mt-4 text-sm font-semibold text-neutral-900">
								<cite class="not-italic">— {item.name}</cite>
							</footer>
						</blockquote>
					</article>
				</li>
			))
		}
	</ul>
</section>
